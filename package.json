{
  "name": "local-agent-bridge",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "local-agent-bridge": "src/cli.ts"
  },
  "exports": {
    ".": {
      "types": "./react/index.ts",
      "import": "./dist/react/index.js"
    },
    "./protocol": {
      "types": "./src/protocol.ts",
      "import": "./dist/protocol.js"
    }
  },
  "scripts": {
    "dev": "bun src/cli.ts",
    "build": "bun build react/index.ts --outdir dist/react --external react --external react-dom --target browser && bun build src/protocol.ts --outdir dist --target browser",
    "test": "bun test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "convex": "^1.21.0",
    "open": "^10.1.0",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
